primary_color = hsl(340, 100%, 45%) // #E6004D
text_color = hsl(340, 30%, 20%) // #42242E
bg_color = #F7F0FA
bg_color_gradient_start = bg_color
bg_color_gradient_end =  #E2CFEF

primary_color_dark = hsl(340, 100%, 70%) // #FF6699
text_color_dark = hsl(0, 0%, 100%) // #FFFFFF
bg_color_dark = #170E1B
bg_color_gradient_start_dark = bg_color_dark
bg_color_gradient_end_dark = #482B56

code_bg_dark = lighten(bg_color_dark, 8%)
code_text_dark = text_color_dark
code_bg_light = darken(bg_color, 3%)
code_text_light = text_color

default_radius = 0.25rem
default_font = -apple-system, BlinkMacSystemFont, "Segoe UI",
  Helvetica, Arial, sans-serif,
  "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol"; // Github's system font stack

breakpoints = {
  sm: 640px,
  md: 768px,
  lg: 1024px,
  xl: 1280px
}

desktop_text_scale = 1.200rem
mobile_text_scale = 1.125rem

// If you dont know what a text scale is,
// refer https://medium.com/sketch-app-sources/exploring-responsive-type-scales-cf1da541be54
