---
eleventyComputed:
  title: "{% if pagination.pageNumber > 0 %}Page {{ pagination.pageNumber + 1 }}{% else %}Home{% endif %}"
layout: layouts/base.njk
permalink: /{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}
pagination:
  data: collections.post
  size: 6
  alias: posts
  reverse: true
eleventyNavigation:
  key: Home
  weight: 0
---

<div class="container">
  <div class="hero text-center">
    {% if site.hero.logo %}
      <img 
        src="{{ site.hero.logo | url }}" 
        alt="{{ site.hero.title }}" 
        style="max-width: 50px; height: auto; margin: 0;" 
      >
    {% endif %}

  {% if site.hero.description %}
    <p class="hero__description">
      {{ site.hero.description }}
    </p>
  {% endif %}
</div>

  <h2 class="section-title">
    {%- if pagination.pageNumber != 0 %} - Page {{ pagination.pageNumber + 1 }}{% endif %}
  </h2>

  {% include "components/postslist.njk" %}

  <div class="pagination">
    {% if pagination.previous %}
      <a href="{{ pagination.href.previous | url }}" class="pagination__prev">&larr; Prev Page</a>
    {% endif %}
    {% if pagination.next %}
      <a href="{{ pagination.href.next | url }}" class="pagination__next">Next Page &rarr;</a>
    {% endif %}
  </div>
</div>
